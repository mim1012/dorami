# ===========================================
# Dorami Production Environment Configuration
# ===========================================
# IMPORTANT: Copy this file to .env.production and fill in ALL values
# DO NOT commit .env.production to version control
#
# Required fields are marked with [REQUIRED]
# Optional fields have default values or can be empty

# ===========================================
# General
# ===========================================
NODE_ENV=production
APP_VERSION=1.0.0

# ===========================================
# Domain & URLs [REQUIRED]
# ===========================================
# Your production domain (without protocol)
DOMAIN=doremi-live.com

# Frontend URL (used for CORS, redirects)
FRONTEND_URL=https://www.doremi-live.com

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://doremi-live.com,https://www.doremi-live.com

# ===========================================
# Database (PostgreSQL) [REQUIRED]
# ===========================================
POSTGRES_USER=dorami_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_DB=dorami_production

# Full connection URL [REQUIRED]
# Format: postgresql://username:password@host:port/database?schema=public
# For Docker Compose: postgres service is accessible as 'postgres:5432'
# For AWS RDS: use your RDS endpoint (e.g., rds-xyz.rds.amazonaws.com)
DATABASE_URL=postgresql://dorami_prod:REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS@postgres:5432/dorami_production

# ===========================================
# Redis [REQUIRED]
# ===========================================
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS

# ===========================================
# JWT Authentication [REQUIRED]
# ===========================================
# MUST be at least 64 characters for production
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_STRING_USE_OPENSSL_RAND_BASE64_64

# Token expiration
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Encryption [REQUIRED]
# ===========================================
# MUST be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
PROFILE_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_USE_OPENSSL_RAND_HEX_32

# ===========================================
# Kakao OAuth [REQUIRED]
# ===========================================
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_CALLBACK_URL=https://www.doremi-live.com/api/auth/kakao/callback

# ===========================================
# Logging
# ===========================================
# Options: error, warn, info, debug
LOG_LEVEL=warn

# ===========================================
# Streaming (SRS Media Server) [REQUIRED for OBS]
# ===========================================
# RTMP ingest URL shown to OBS users — MUST include :1935 port
RTMP_SERVER_URL=rtmp://www.doremi-live.com:1935/live
# Internal RTMP URL used by restream service (Docker service name)
RTMP_INTERNAL_URL=rtmp://srs:1935/live
# HLS playback base URL
HLS_SERVER_URL=https://www.doremi-live.com/hls

# ===========================================
# Frontend Build Args [REQUIRED]
# ===========================================
# These are embedded at build time
NEXT_PUBLIC_API_URL=https://www.doremi-live.com/api
NEXT_PUBLIC_WS_URL=https://www.doremi-live.com
NEXT_PUBLIC_CDN_URL=https://www.doremi-live.com/hls

# ===========================================
# Error Tracking (Sentry) [RECOMMENDED]
# ===========================================
SENTRY_DSN=https://ed7e4b1bf8fea045f100c20219ce497b@o4511102675648512.ingest.us.sentry.io/4511162539769856
NEXT_PUBLIC_SENTRY_DSN=https://66827a7b76b4aa2c8d0c876e981d2942@o4511102675648512.ingest.us.sentry.io/4511162525089792
# Sentry source map upload (CI/CD only)
SENTRY_AUTH_TOKEN=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
SENTRY_ORG=bizsolution
SENTRY_PROJECT=dorami-frontend-production
SENTRY_PROJECT_BACKEND=dorami-backend-production

# ===========================================
# Admin Configuration
# ===========================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@doremi-live.com

# ===========================================
# Monitoring (Grafana) [REQUIRED]
# ===========================================
# IMPORTANT: Use GitHub Secrets to inject this value in production
# GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD:?GRAFANA_ADMIN_PASSWORD required}
# For local .env.production: generate with `openssl rand -base64 32`
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS

# ===========================================
# Security
# ===========================================
CSRF_ENABLED=true
DISABLE_CSRF=false

# ===========================================
# Resource Limits (Docker)
# ===========================================
# Adjust based on your server capacity
# POSTGRES_CPU_LIMIT=2
# POSTGRES_MEMORY_LIMIT=2G
# BACKEND_CPU_LIMIT=2
# BACKEND_MEMORY_LIMIT=1G
# FRONTEND_CPU_LIMIT=1
# FRONTEND_MEMORY_LIMIT=512M
