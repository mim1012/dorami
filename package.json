{
  "name": "live-commerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Live Commerce Platform - Monorepo",
  "workspaces": [
    "packages/*",
    "client-app",
    "backend"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client-app",
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:all": "concurrently \"npm run dev:client\" \"npm run dev:backend\"",
    "build:client": "npm run build --workspace=client-app",
    "build:backend": "npm run build --workspace=backend",
    "build:shared": "npm run build --workspace=@live-commerce/shared-types",
    "build:all": "npm run build:shared && npm run build:client && npm run build:backend",
    "type-check:client": "npm run type-check --workspace=client-app",
    "type-check:backend": "npm run build --workspace=backend",
    "type-check:shared": "npm run type-check --workspace=@live-commerce/shared-types",
    "type-check:all": "npm run type-check:shared && npm run type-check:client && npm run type-check:backend",
    "test:backend": "npm run test --workspace=backend",
    "test:client": "jest --config client-app/jest.config.js --rootDir client-app",
    "test:e2e": "npm run test:e2e --workspace=backend",
    "test:all": "npm run test:backend && npm run test:client && npm run test:e2e",
    "smoke:check": "node ./scripts/smoke-check.mjs",
    "smoke:binding": "node ./scripts/smoke-api-ui-binding.mjs",
    "smoke:e2e": "npm run e2e:smoke --workspace=client-app",
    "test:e2e:binding": "npm run test:e2e --workspace=backend -- health.binding.e2e-spec.ts notifications.binding.e2e-spec.ts",
    "preflight:binding": "npm run test:e2e:binding && npm run smoke:binding",
    "lint:client": "npm run lint --workspace=client-app",
    "lint:backend": "npm run lint --workspace=backend",
    "lint:all": "npm run lint:client && npm run lint:backend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:docker": "docker-compose up -d && docker-compose logs -f frontend backend",
    "dev:host": "npm run dev:all",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:staging": "docker-compose -f docker-compose.yml -f docker-compose.staging.yml up -d && docker-compose logs -f",
    "docker:rebuild": "docker-compose down && docker-compose build --no-cache frontend && docker-compose up -d",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:migrate": "npm run prisma:migrate:dev --workspace=backend",
    "prisma:studio": "npm run prisma:studio --workspace=backend",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "postinstall": "npm run build:shared",
    "prepare": "node -e \"if (process.env.CI !== 'true') { try { var husky = require('husky'); if (husky.default) husky.default(); } catch (e) { /* husky not installed yet */ } }\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "backend/src/**/*.spec.ts": [
      "prettier --write"
    ],
    "backend/src/**/!(*.spec).ts": [
      "eslint --config backend/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "client-app/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "packages/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "passport-oauth2": "^1.8.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@sentry/profiling-node": "^10.38.0"
  }
}
