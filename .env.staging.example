# Staging Environment Variables
# Canonical source: .github/workflows/deploy-staging.yml "Creating .env.staging" step
# This file documents all variables the staging deployment generates.

# === Database ===
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@postgres:5432/live_commerce_staging"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="YOUR_PASSWORD"
POSTGRES_DB="live_commerce_staging"

# === Redis ===
REDIS_URL="redis://:YOUR_REDIS_PASSWORD@redis:6379"
REDIS_PASSWORD="YOUR_REDIS_PASSWORD"
REDIS_HOST="redis"
REDIS_PORT="6379"

# === Auth & Security ===
JWT_SECRET="YOUR_JWT_SECRET_MIN_32_CHARS"
PROFILE_ENCRYPTION_KEY="YOUR_64_HEX_CHAR_KEY"
CSRF_ENABLED="false"

# === Kakao OAuth ===
KAKAO_CLIENT_ID="YOUR_KAKAO_REST_API_KEY"
KAKAO_CLIENT_SECRET="YOUR_KAKAO_CLIENT_SECRET"
KAKAO_CALLBACK_URL="https://staging.doremi-live.com/api/auth/kakao/callback"
KAKAO_JS_KEY="YOUR_KAKAO_JS_KEY"
NEXT_PUBLIC_KAKAO_JS_KEY="YOUR_KAKAO_JS_KEY"
KAKAO_EXTERNAL_ORIGIN="https://staging.doremi-live.com"

# === Admin ===
ADMIN_EMAILS="admin@doremi.shop"

# === Docker Image ===
IMAGE_TAG="sha-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GITHUB_REPOSITORY_OWNER="your-github-org"

# === App Config ===
APP_ENV="staging"
NODE_ENV="production"
PORT="3001"
CORS_ORIGINS="https://staging.doremi-live.com,http://staging.doremi-live.com,http://localhost:3000"
FRONTEND_URL="https://staging.doremi-live.com"
ENABLE_DEV_AUTH="true"
LOG_LEVEL="debug"

# === Streaming ===
RTMP_INTERNAL_URL="rtmp://srs:1935/live"
RTMP_EXTERNAL_URL="rtmp://staging.doremi-live.com:1935/live"
HLS_SERVER_URL="http://staging.doremi-live.com/hls"
MEDIA_SERVER_URL="http://localhost:8080"
SRS_API_URL="http://srs:1985"
SRS_WEBHOOK_SECRET="YOUR_SRS_WEBHOOK_SECRET"

# === WebSocket ===
WS_URL="wss://staging.doremi-live.com"

