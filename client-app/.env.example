# ──────────────────────────────────────────────
# Next.js Frontend Environment Variables
# ──────────────────────────────────────────────
# 로컬 개발용: .env.local에 복사 후 값 입력
# 스테이징/프로덕션: 모든 값은 docker-compose --env-file 로 주입됨

# ── Build-time (NEXT_PUBLIC_*) ────────────────
# 이 값들은 빌드 시 번들에 포함됨 — 재빌드 없이 변경 불가

# 카카오 JavaScript 키 — https://developers.kakao.com
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key_here

# Sentry 에러 트래킹 DSN
NEXT_PUBLIC_SENTRY_DSN=

# ── Runtime (서버 환경변수, /api/config 경유) ──
# 이 값들은 런타임에 /api/config API로 제공됨 — 재빌드 불필요

# WebSocket 서버 URL (로컬 dev만 명시; staging/prod은 window.location.origin 자동 사용)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# 서버사이드 env (docker-compose에서 WS_URL로 주입)
WS_URL=http://localhost:3001

# 카카오톡 인앱 브라우저용 공개 도메인 (미들웨어 서버사이드 env)
KAKAO_EXTERNAL_ORIGIN=http://localhost:3000

# VAPID 공개키 (Web Push)
VAPID_PUBLIC_KEY=

# 개발 로그인 활성화 (스테이징만 true)
ENABLE_DEV_AUTH=true

# 라이브 미리보기 페이지 활성화
PREVIEW_ENABLED=

# CDN URL (HLS 영상 배포용, 없으면 로컬 nginx 경유)
CDN_URL=

# 앱 환경 (development | staging | production)
APP_ENV=development
APP_VERSION=1.0.0

# 카카오톡 채널 공개 ID (예: _NJMzX) — https://center-pf.kakao.com
KAKAO_CHANNEL_ID=_NJMzX
# 인스타그램 계정 ID (@ 제외)
INSTAGRAM_ID=doremiusa

# ── Next.js Proxy ─────────────────────────────
# /api/* → backend
BACKEND_URL=http://localhost:3001
# /live/*, /hls/* → SRS media server
MEDIA_SERVER_URL=http://localhost:8080
