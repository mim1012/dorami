NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Live Preview Page (staging only)
# Set to "true" to enable /live/preview in production builds
NEXT_PUBLIC_PREVIEW_ENABLED=

# Error Tracking (Sentry)
# Get your DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_VERSION=1.0.0

# 카카오톡 인앱 브라우저용 공개 도메인(필수)
# 0.0.0.0:3000 같은 내부 주소로 노출되는 문제를 방지합니다.
NEXT_PUBLIC_KAKAO_EXTERNAL_ORIGIN=https://your-real-domain.com

# 카카오톡 채널 공개 ID (예: _wxxxxxx) — https://center-pf.kakao.com 에서 확인
NEXT_PUBLIC_KAKAO_CHANNEL_ID=
# 카카오 JavaScript 키 — https://developers.kakao.com 에서 확인
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key_here
# 인스타그램 계정 ID (@ 제외)
NEXT_PUBLIC_INSTAGRAM_ID=doremiusa
