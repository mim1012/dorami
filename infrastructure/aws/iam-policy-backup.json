{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BackupS3PutGet",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::dorami-db-backups-prod",
        "arn:aws:s3:::dorami-db-backups-prod/backups/*"
      ]
    }
  ]
}
